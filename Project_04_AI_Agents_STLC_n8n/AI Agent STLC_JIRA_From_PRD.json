    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a senior QA engineer. Based on the following PRD content, create a comprehensive test plan in Markdown format.\\n\\nPRD Content:\\n{{ $json.data }}\\n\\nGenerate a test plan covering:\\n- Project Overview (product name, scope, version)\\n- Test Objectives\\n- Features to be Tested (one section per feature from the PRD)\\n- Features NOT to be Tested (explicitly out of scope)\\n- Test Types (Functional, Regression, Edge Cases, Negative Testing, UI/UX)\\n- Test Environment & Prerequisites\\n- Entry and Exit Criteria\\n- Risk Assessment\\n- Test Schedule / Effort Estimate\\n\\nReturn ONLY the markdown content, no additional commentary.",
        "options": {
          "systemMessage": "You are a senior QA engineer specialized in creating comprehensive test plans. Generate detailed, structured test documentation based on PRD inputs.",
          "maxIterations": 5
        }
      },
      "id": "3c8e0a1c-bdea-40bf-89e3-484f35b06473",
      "name": "Generate Test Plan",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        0
      ]
    },
