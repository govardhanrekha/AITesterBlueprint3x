    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a senior QA engineer. Based on the following PRD content, create detailed test cases in CSV format.\\n\\nPRD Content:\\n{{ $(\"Extract PDF Content\").item.json.data }}\\n\\nGenerate test cases with these exact columns:\\nTest Case ID,Feature,Test Scenario,Test Steps,Expected Result,Priority,Type\\n\\nExample format:\\nTC001,User Authentication,Verify user can sign up with valid email,Step 1: Navigate to signup page; Step 2: Enter valid email; Step 3: Enter password; Step 4: Click Sign Up,User account created successfully,High,Functional\\n\\nCreate comprehensive test cases covering:\\n- Functional testing\\n- Edge cases\\n- Negative testing\\n- UI/UX validation\\n\\nReturn ONLY the CSV content with header row, no additional commentary.",
        "options": {
          "systemMessage": "You are a senior QA engineer specialized in creating detailed test cases. Generate comprehensive CSV test case documentation.",
          "maxIterations": 5
        }
      },
      "id": "e495638d-8146-4d4c-96ce-fce72e098a61",
      "name": "Generate Test Cases",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        400
      ]
    },
    {
      "parameters": {
        "operation": "toText",
        "sourceProperty": "output",
        "binaryPropertyName": "test_cases",
        "options": {
