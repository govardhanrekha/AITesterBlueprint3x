        }
      },
      "id": "1e41855f-d5d4-4f82-a0fd-047c0d2a31f8",
      "name": "Create test_cases.csv",
      "type": "n8n-nodes-base.convertToFile",
      "typeVersion": 1.1,
      "position": [
        1024,
        400
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a senior QA automation engineer. Based on the following PRD content, create Playwright test scripts in Markdown format.\\n\\nPRD Content:\\n{{ $(\"Extract PDF Content\").item.json.data }}\\n\\nGenerate Playwright test scripts covering all features. Use this structure:\\n\\n```javascript\\nimport { test, expect } from '@playwright/test';\\n\\ntest.describe('Feature Name', () => {\\n  test('test scenario', async ({ page }) => {\\n    // test steps\\n  });\\n});\\n```\\n\\nCreate comprehensive automated tests for:\\n- User flows\\n- Form validations\\n- API interactions\\n- UI element verification\\n\\nReturn the content as a Markdown document with code blocks. Include setup instructions and best practices.",
        "options": {
          "systemMessage": "You are a senior QA automation engineer specialized in Playwright. Generate production-ready test automation scripts.",
          "maxIterations": 5
        }
      },
      "id": "ce1b3aae-0492-451c-a335-7ab8d1c3441d",
      "name": "Generate Playwright Scripts",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        672,
        592
      ]
    },
    {
      "parameters": {
        "operation": "toText",
        "sourceProperty": "output",
        "binaryPropertyName": "playwright_scripts",
        "options": {
          "fileName": "playwright_test_cases.md"
        }
      },
      "id": "e534f1f1-6310-4029-8676-eedbbfc3b82d",
      "name": "Create playwright_test_cases.md",
      "type": "n8n-nodes-base.convertToFile",
      "typeVersion": 1.1,
      "position": [
        1024,
        592
      ]
    },
    {
      "parameters": {
        "jsCode": "// Collect all generated files\nconst items = $input.all();\nconst files = [];\n\nfor (const item of items) {\n  if (item.json.test_plan) {\n    files.push('✅ test_plan.md');\n  }\n  if (item.json.test_cases) {\n    files.push('✅ test_cases.csv');\n  }\n  if (item.json.playwright_scripts) {\n    files.push('✅ playwright_test_cases.md');\n  }\n}\n\nreturn [{\n  json: {\n    output: `Successfully generated all test artifacts:\\n\\n${files.join('\\n')}\\n\\nAll files are ready for download.`\n  }\n}];"
      },
      "id": "d1eb542e-f8f0-4781-b8ec-7995b3717655",
